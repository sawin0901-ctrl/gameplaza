generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                  String         @id @default(cuid())
  name                String?
  email               String         @unique
  password            String
  role                String         @default("user")
  isBlocked           Boolean        @default(false)
  balance             Float          @default(0)
  emailVerified       DateTime?
  verificationToken   String?
  resetToken          String?
  resetTokenExpiry    DateTime?
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt
  wishlists           Wishlist[]
  reviews             Review[]
  orders              Order[]
  loginHistory        LoginHistory[]
  tickets             Ticket[]
  referralCodes       ReferralCode[]
}

model Product {
  id                  String       @id @default(cuid())
  digisellerProductId Int          @unique
  name                String
  slug                String       @unique
  description         String       @db.Text
  shortDesc           String?      @db.Text
  price               Float
  oldPrice            Float?
  discountPercent     Int?
  currency            String       @default("RUB")
  imageUrl            String?
  galleryImages       String[]
  videoUrl            String?
  importSource        String?
  platiUrl            String?
  metaTitle           String?
  metaDescription     String?
  metaKeywords        String?
  categoryId          String?
  category            Category?    @relation(fields: [categoryId], references: [id])
  isActive            Boolean      @default(false)
  inStock             Boolean      @default(true)
  quantity            Int          @default(0)
  rating              Float?
  reviewCount         Int?
  soldCount           Int          @default(0)
  relatedProducts     Product[]    @relation("RelatedProducts")
  relatedTo           Product[]    @relation("RelatedProducts")
  importedAt          DateTime     @default(now())
  updatedAt           DateTime     @updatedAt
  lastCheckedAt       DateTime?
  hiddenAt            DateTime?
  hideReason          String?
  wishlists           Wishlist[]
  reviews             Review[]
  orderItems          OrderItem[]
  keys                ProductKey[]
  flashSales          FlashSale[]
  bundleItems         BundleItem[]

  @@index([isActive])
  @@index([importSource])
  @@index([lastCheckedAt])
  @@index([importSource, lastCheckedAt])
  @@index([isActive, importedAt])
}

model PlatiImportLog {
  id          String   @id @default(cuid())
  url         String
  productId   Int?
  productName String?
  status      String
  error       String?
  duration    Int?
  source      String   @default("manual")
  createdAt   DateTime @default(now())

  @@index([createdAt])
  @@index([status])
  @@index([source])
}

model Category {
  id          String    @id @default(cuid())
  name        String
  slug        String    @unique
  description String?
  imageUrl    String?
  color       String?
  metaTitle   String?
  metaDesc    String?
  products    Product[]
  createdAt   DateTime  @default(now())
}

model Order {
  id            String      @id @default(cuid())
  userId        String?
  email         String
  status        String      @default("pending")
  totalAmount   Float
  promoCode     String?
  discount      Float       @default(0)
  paymentMethod String?
  paymentId     String?
  notes         String?
  refundReason  String?
  items         OrderItem[]
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  user          User?       @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([status])
  @@index([createdAt])
  @@index([email])
}

model OrderItem {
  id        String   @id @default(cuid())
  orderId   String
  productId String?
  name      String
  price     Float
  digiId    Int
  imageUrl  String?
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product   Product? @relation(fields: [productId], references: [id], onDelete: SetNull)
}

model PromoCode {
  id             String    @id @default(cuid())
  code           String    @unique
  description    String?
  type           String    @default("percent")
  value          Float
  minOrderAmount Float?
  maxUses        Int?
  usedCount      Int       @default(0)
  expiresAt      DateTime?
  isActive       Boolean   @default(true)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([code])
  @@index([isActive])
}

model LoginHistory {
  id        String   @id @default(cuid())
  userId    String
  ip        String?
  userAgent String?
  city      String?
  country   String?
  success   Boolean  @default(true)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
}

model ImportQueue {
  id                  String    @id @default(cuid())
  digisellerProductId Int       @unique
  status              String    @default("pending")
  priority            Int       @default(0)
  attempts            Int       @default(0)
  lastError           String?
  scheduledAt         DateTime  @default(now())
  processedAt         DateTime?
  createdAt           DateTime  @default(now())
}

model ImportLog {
  id       String   @id @default(cuid())
  date     DateTime @default(now()) @unique
  imported Int      @default(0)
  updated  Int      @default(0)
  hidden   Int      @default(0)
  restored Int      @default(0)
  errors   Int      @default(0)
  duration Int?
}

model SystemSetting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

model Wishlist {
  id        String   @id @default(cuid())
  userId    String
  productId String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
}

model Review {
  id         String   @id @default(cuid())
  productId  String
  userId     String?
  rating     Int
  text       String   @db.Text
  isApproved Boolean  @default(true)
  source     String   @default("site")
  authorName String?
  createdAt  DateTime @default(now())
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  user       User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@unique([productId, userId])
}

model PageView {
  id             String   @id @default(cuid())
  sessionId      String
  userId         String?
  path           String
  referrer       String?
  referrerType   String?
  referrerSource String?
  keyword        String?
  utmSource      String?
  utmMedium      String?
  utmCampaign    String?
  utmContent     String?
  utmTerm        String?
  country        String?
  city           String?
  device         String?
  browser        String?
  os             String?
  duration       Int?
  createdAt      DateTime @default(now())

  @@index([createdAt])
  @@index([path])
  @@index([sessionId])
  @@index([referrerType])
  @@index([country])
  @@index([utmCampaign])
}

model AnalyticsEvent {
  id        String   @id @default(cuid())
  sessionId String
  userId    String?
  event     String
  path      String?
  productId String?
  orderId   String?
  value     Float?
  meta      Json?
  createdAt DateTime @default(now())

  @@index([createdAt])
  @@index([event])
  @@index([productId])
}

model DailyStats {
  id             String   @id @default(cuid())
  date           DateTime @unique
  pageViews      Int      @default(0)
  sessions       Int      @default(0)
  uniqueVisitors Int      @default(0)
  orders         Int      @default(0)
  revenue        Float    @default(0)
  registrations  Int      @default(0)

  @@index([date])
}

model SystemLog {
  id         String    @id @default(cuid())
  level      String
  category   String
  message    String
  details    Json?
  url        String?
  userId     String?
  status     String    @default("new")
  resolvedAt DateTime?
  resolvedBy String?
  createdAt  DateTime  @default(now())

  @@index([createdAt])
  @@index([level])
  @@index([category])
  @@index([status])
}

model Banner {
  id        String   @id @default(cuid())
  title     String
  subtitle  String?
  imageUrl  String
  linkUrl   String?
  isActive  Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model FAQItem {
  id        String   @id @default(cuid())
  question  String
  answer    String   @db.Text
  category  String   @default("general")
  sortOrder Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive])
}

model ProductKey {
  id        String    @id @default(cuid())
  productId String
  keyValue  String
  isUsed    Boolean   @default(false)
  orderId   String?
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  product   Product   @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@index([isUsed])
}

model FlashSale {
  id            String   @id @default(cuid())
  productId     String
  discountValue Float
  discountType  String   @default("percent")
  startAt       DateTime
  endAt         DateTime
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  product       Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([endAt])
  @@index([isActive])
}

model Bundle {
  id          String       @id @default(cuid())
  name        String
  slug        String       @unique
  description String?      @db.Text
  imageUrl    String?
  price       Float
  isActive    Boolean      @default(true)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  items       BundleItem[]
}

model BundleItem {
  id        String  @id @default(cuid())
  bundleId  String
  productId String
  bundle    Bundle  @relation(fields: [bundleId], references: [id], onDelete: Cascade)
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model Ticket {
  id        String          @id @default(cuid())
  userId    String?
  email     String
  subject   String
  status    String          @default("open")
  priority  String          @default("normal")
  orderId   String?
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
  user      User?           @relation(fields: [userId], references: [id], onDelete: SetNull)
  messages  TicketMessage[]

  @@index([status])
  @@index([userId])
  @@index([createdAt])
}

model TicketMessage {
  id        String   @id @default(cuid())
  ticketId  String
  isAdmin   Boolean  @default(false)
  text      String   @db.Text
  createdAt DateTime @default(now())
  ticket    Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
}

model ReferralCode {
  id          String   @id @default(cuid())
  userId      String
  code        String   @unique
  usedCount   Int      @default(0)
  bonusAmount Float    @default(50)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([code])
}

model AdminLog {
  id         String   @id @default(cuid())
  adminId    String
  adminEmail String
  action     String
  entity     String?
  entityId   String?
  details    Json?
  ip         String?
  createdAt  DateTime @default(now())

  @@index([createdAt])
  @@index([adminId])
  @@index([action])
}
model AutoImportSession {
  id         String          @id @default(cuid())
  status     String          @default("idle")
  mode       String          @default("list")
  startId    Int             @default(0)
  endId      Int             @default(0)
  currentId  Int             @default(0)
  totalCount Int             @default(0)
  doneCount  Int             @default(0)
  errorCount Int             @default(0)
  skipCount  Int             @default(0)
  dupCount   Int             @default(0)
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt
  items      AutoImportItem[]
  logs       AutoImportLog[]
}

model AutoImportItem {
  id          String            @id @default(cuid())
  sessionId   String
  platiId     Int
  status      String            @default("pending")
  processedAt DateTime?
  session     AutoImportSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@unique([sessionId, platiId])
  @@index([sessionId, status])
}

model AutoImportLog {
  id          String            @id @default(cuid())
  sessionId   String
  platiId     Int
  status      String
  productName String?
  errorMsg    String?
  duration    Int?
  createdAt   DateTime          @default(now())
  session     AutoImportSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId, createdAt(sort: Desc)])
}