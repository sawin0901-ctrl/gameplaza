generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                  String         @id @default(cuid())
  name                String?
  email               String         @unique
  password            String
  role                String         @default("user")
  emailVerified       DateTime?
  verificationToken   String?
  resetToken          String?
  resetTokenExpiry    DateTime?
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt
  wishlists           Wishlist[]
  reviews             Review[]
  orders              Order[]
  loginHistory        LoginHistory[]
}

model Product {
  id                  String    @id @default(cuid())
  digisellerProductId Int       @unique
  name                String
  slug                String    @unique
  description         String    @db.Text
  price               Float
  oldPrice            Float?
  discountPercent     Int?
  currency            String    @default("RUB")
  imageUrl            String?
  categoryId          String?
  category            Category? @relation(fields: [categoryId], references: [id])
  isActive            Boolean   @default(false)
  inStock             Boolean   @default(true)
  quantity            Int       @default(0)
  rating              Float?
  reviewCount         Int?
  soldCount           Int       @default(0)
  metaTitle           String?
  metaDescription     String?
  relatedProducts     Product[] @relation("RelatedProducts")
  relatedTo           Product[] @relation("RelatedProducts")
  importedAt          DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  lastCheckedAt       DateTime?
  hiddenAt            DateTime?
  hideReason          String?
  wishlists           Wishlist[]
  reviews             Review[]
  orderItems          OrderItem[]
}

model Category {
  id          String    @id @default(cuid())
  name        String
  slug        String    @unique
  description String?
  imageUrl    String?
  color       String?
  products    Product[]
  createdAt   DateTime  @default(now())
}

model Order {
  id            String      @id @default(cuid())
  userId        String?
  email         String
  status        String      @default("pending")
  totalAmount   Float
  promoCode     String?
  discount      Float       @default(0)
  paymentMethod String?
  paymentId     String?
  notes         String?
  items         OrderItem[]
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  user          User?       @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([status])
  @@index([createdAt])
  @@index([email])
}

model OrderItem {
  id        String   @id @default(cuid())
  orderId   String
  productId String?
  name      String
  price     Float
  digiId    Int
  imageUrl  String?
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product   Product? @relation(fields: [productId], references: [id], onDelete: SetNull)
}

model PromoCode {
  id             String    @id @default(cuid())
  code           String    @unique
  description    String?
  type           String    @default("percent")
  value          Float
  minOrderAmount Float?
  maxUses        Int?
  usedCount      Int       @default(0)
  expiresAt      DateTime?
  isActive       Boolean   @default(true)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([code])
  @@index([isActive])
}

model LoginHistory {
  id        String   @id @default(cuid())
  userId    String
  ip        String?
  userAgent String?
  city      String?
  country   String?
  success   Boolean  @default(true)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
}

model ImportQueue {
  id                  String    @id @default(cuid())
  digisellerProductId Int       @unique
  status              String    @default("pending")
  priority            Int       @default(0)
  attempts            Int       @default(0)
  lastError           String?
  scheduledAt         DateTime  @default(now())
  processedAt         DateTime?
  createdAt           DateTime  @default(now())
}

model ImportLog {
  id       String   @id @default(cuid())
  date     DateTime @default(now())
  imported Int      @default(0)
  updated  Int      @default(0)
  hidden   Int      @default(0)
  restored Int      @default(0)
  errors   Int      @default(0)
  duration Int?
}

model SystemSetting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

model Wishlist {
  id        String   @id @default(cuid())
  userId    String
  productId String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
}

model Review {
  id        String   @id @default(cuid())
  productId String
  userId    String
  rating    Int
  text      String   @db.Text
  createdAt DateTime @default(now())
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([productId, userId])
}

model PageView {
  id             String   @id @default(cuid())
  sessionId      String
  userId         String?
  path           String
  referrer       String?
  referrerType   String?
  referrerSource String?
  keyword        String?
  utmSource      String?
  utmMedium      String?
  utmCampaign    String?
  utmContent     String?
  utmTerm        String?
  country        String?
  city           String?
  device         String?
  browser        String?
  os             String?
  duration       Int?
  createdAt      DateTime @default(now())

  @@index([createdAt])
  @@index([path])
  @@index([sessionId])
  @@index([referrerType])
  @@index([country])
  @@index([utmCampaign])
}

model AnalyticsEvent {
  id        String   @id @default(cuid())
  sessionId String
  userId    String?
  event     String
  path      String?
  productId String?
  orderId   String?
  value     Float?
  meta      Json?
  createdAt DateTime @default(now())

  @@index([createdAt])
  @@index([event])
  @@index([productId])
}

model DailyStats {
  id             String   @id @default(cuid())
  date           DateTime @unique
  pageViews      Int      @default(0)
  sessions       Int      @default(0)
  uniqueVisitors Int      @default(0)
  orders         Int      @default(0)
  revenue        Float    @default(0)
  registrations  Int      @default(0)

  @@index([date])
}

model SystemLog {
  id         String    @id @default(cuid())
  level      String
  category   String
  message    String
  details    Json?
  url        String?
  userId     String?
  status     String    @default("new")
  resolvedAt DateTime?
  resolvedBy String?
  createdAt  DateTime  @default(now())

  @@index([createdAt])
  @@index([level])
  @@index([category])
  @@index([status])
}
