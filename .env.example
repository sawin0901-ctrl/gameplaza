# =========================================================
# GamePlaza — пример файла переменных окружения
# Скопируйте в .env и заполните реальными значениями
# =========================================================

# --- База данных ---
DATABASE_URL="postgresql://user:password@localhost:5432/gameplaza"

# --- Redis (BullMQ очередь импорта) ---
REDIS_URL="redis://localhost:6379"

# --- NextAuth ---
# Генерация секрета: openssl rand -base64 32
NEXTAUTH_SECRET="your-secret-here"
NEXTAUTH_URL="https://gameplaza.site"

# --- Digiseller ---
DIGISELLER_SELLER_ID="your-seller-id"
DIGISELLER_API_KEY="your-api-key"

# --- AI (Gemini) ---
GEMINI_API_KEY="your-gemini-api-key"

# --- Сайт ---
NEXT_PUBLIC_SITE_URL="https://gameplaza.site"

# --- Безопасность ---
# Генерация: openssl rand -hex 32
ADMIN_SECRET="your-admin-secret"

# =========================================================
# EMAIL (SMTP) — верификация email, сброс пароля
# =========================================================
# Рекомендуемый провайдер: Resend (resend.com) — бесплатно 100 писем/день
#   SMTP_HOST=smtp.resend.com
#   SMTP_PORT=465
#   SMTP_SECURE=true
#   SMTP_USER=resend
#   SMTP_PASS=re_xxxxxxxxxxxxxx  (API key из resend.com)
#
# Или Gmail (нужен App Password, не обычный пароль):
#   SMTP_HOST=smtp.gmail.com
#   SMTP_PORT=587
#   SMTP_SECURE=false
#   SMTP_USER=your-gmail@gmail.com
#   SMTP_PASS=xxxx-xxxx-xxxx-xxxx  (App Password из myaccount.google.com)
#
# Или Mailgun, SendGrid, Brevo (Sendinblue) — аналогично
# =========================================================
SMTP_HOST="smtp.resend.com"
SMTP_PORT="465"
SMTP_SECURE="true"
SMTP_USER="resend"
SMTP_PASS="re_your_api_key"
SMTP_FROM='"GamePlaza" <noreply@gameplaza.site>'

# =========================================================
# SENTRY — мониторинг ошибок (бесплатно на sentry.io)
# 1. Зарегистрируйтесь на sentry.io
# 2. Создайте проект "Next.js"
# 3. Скопируйте DSN из Settings → Client Keys
# =========================================================
SENTRY_DSN="https://your-key@o0.ingest.sentry.io/0"
NEXT_PUBLIC_SENTRY_DSN="https://your-key@o0.ingest.sentry.io/0"

# Google Search Console (опционально)
GOOGLE_SITE_VERIFICATION=""
